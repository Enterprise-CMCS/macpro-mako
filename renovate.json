{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "includePaths": ["lib/attachment-archive/**", "lib/local-constructs/clamav-scanning/**"],
  "dependencyDashboard": true,
  "labels": ["dependencies", "security"],
  "packageRules": [
    {
      "matchManagers": ["bun", "npm"],
      "matchFileNames": [
        "lib/attachment-archive/package.json",
        "lib/local-constructs/clamav-scanning/package.json"
      ],
      "matchPackagePrefixes": ["@aws-sdk/"],
      "groupName": "container aws sdk"
    },
    {
      "matchManagers": ["dockerfile"],
      "matchFileNames": [
        "lib/attachment-archive/Dockerfile",
        "lib/local-constructs/clamav-scanning/Dockerfile"
      ],
      "groupName": "container base images"
    },
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}
